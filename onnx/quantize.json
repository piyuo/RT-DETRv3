{
  "input_model": {
    "type": "ONNXModel",
    "model_path": "onnx/backbone/rtdetrv3_r18vd_6x.onnx"
  },
  "systems": {
    "local_system": {
      "type": "LocalSystem",
      "accelerators": [
        {
          "device": "cpu",
          "execution_providers": ["CPUExecutionProvider"]
        }
      ]
    },
    "coreml_system": {
      "type": "LocalSystem",
      "accelerators": [
        {
          "device": "gpu",
          "execution_providers": ["CoreMLExecutionProvider"],
          "apple_gpu_only": false,
          "apple_ane_only": true
        }
      ]
    }
  },

  "data_configs": [
    {
      "name": "coco_val_data",
      "user_script": "onnx/quantize.py",
      "load_dataset_config": {
        "type": "dataset_load",
        "data_dir": "onnx/calibration/img",
        "annotation_file": "onnx/calibration/val2017.json"
      },
      "post_process_data_config": { "type": "dataset_post_process" }
    }
  ],
  "passes": {
    "peephole_optimizer": {
      "type": "OnnxPeepholeOptimizer"
    },
    "onnx_static_quantization": {
      "type": "OnnxStaticQuantization",
      "data_config": "coco_val_data",
      "quant_format": "QDQ",
      "activation_type": "int8",
      "per_channel": true,
      "op_types_to_quantize": ["Conv", "MatMul"]
    },
    "extract_adapters": {
      "type": "ExtractAdapters"
    }
  },
  "host": "local_system",
  "target": "coreml_system",
  "no_artifacts": true,
  "output_dir": "onnx/output/olive",
  "log_severity_level": 1
}
